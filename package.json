{
  "name": "@canopycanopycanopy/b-ber",
  "version": "0.1.7",
  "private": true,
  "license": "GPL-3.0-or-later",
  "engines": {
    "node": ">= 22.x",
    "npm": ">= 10.x"
  },
  "workspaces": ["packages/*"],
  "scripts": {
    "watch": "lerna run watch --stream",
    "build": "lerna run build",
    "bootstrap": "npm install",
    "bootstrap:clean": "lerna clean --yes && npm install && npm run build",
    "check": "biome check .",
    "format": "biome check --write .",
    "lerna": "lerna",
    "jest": "jest",
    "test:coverage": "rimraf ./coverage && jest --collectCoverage=true",
    "test": "npm run check && jest",
    "prepublishOnly": "npm test && npm run build",
    "postpublish": "node scripts/run-ci.js",
    "publish:canary": "lerna publish --canary",
    "publish:latest": "lerna publish",
    "publish:lts-2": "[[ $(git rev-parse --abbrev-ref HEAD) != lts-2 ]] && echo \"ERR: Publishing lts-2 can only be done on the lts-2 branch\" && exit 1 || npm run lerna publish -- --dist-tag lts-2",
    "outdated": "npm outdated || true && lerna exec --no-bail -- npm outdated",
    "deps:update": "lernaupdate",
    "deps:dedupe": "lernaupdate --dedupe",
    "browserlist:update": "npx browserslist@latest --update-db",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0",
    "check:circular": "madge --circular --extensions js,jsx packages/",
    "typecheck": "lerna run typecheck"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json}": [
      "biome check --write --no-errors-on-unmatched",
      "git add"
    ],
    "*.{md,scss,yaml,yml}": [
      "biome format --write --no-errors-on-unmatched",
      "git add"
    ],
    "*.svg": [
      "svgo --pretty --indent=2 --config=svgo.yml --multipass",
      "git add"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "commit-msg": "commitlint --edit $1"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@commitlint/cli": "^16.2.3",
    "@commitlint/config-conventional": "^16.2.1",
    "@swc/core": "^1.15.40",
    "@swc/jest": "^0.2.39",
    "@types/node": "^14.14.7",
    "autoprefixer": "^9.6.1",
    "browserslist": "^4.17.4",
    "buffer": "^6.0.3",
    "classnames": "^2.2.5",
    "concurrently": "^3.5.1",
    "conventional-changelog-cli": "^2.2.2",
    "core-js": "^3.6.4",
    "css-tree": "^2.1.0",
    "cssnano": "^4.1.10",
    "detect-browser": "^2.1.0",
    "express": "^4.17.3",
    "fs-extra": "^8.1.0",
    "handlebars": "^4.7.7",
    "history": "^4.7.2",
    "html-to-react": "^1.4.3",
    "husky": "^1.1.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-environment-jsdom-global": "^4.0.0",
    "jest-extended": "^3.2.4",
    "js-string-escape": "^1.0.1",
    "lerna": "^8",
    "lerna-audit": "^1.2.0",
    "lerna-update-wizard": "^1.1.2",
    "lint-staged": "^9.2.0",
    "lodash": "^4.17.21",
    "madge": "^7.0.0",
    "material-icons": "^1.0.0",
    "mock-fs": "^4.4.2",
    "nodemon": "^2.0.15",
    "object-fit-images": "^3.2.3",
    "os-browserify": "^0.3.0",
    "postcss": "^7.0.14",
    "postcss-cssnext": "^3.1.0",
    "postcss-import": "^11.1.0",
    "prop-types": "^15.6.1",
    "quote": "^0.4.0",
    "react": "^19",
    "react-attr-converter": "^0.3.1",
    "react-dom": "^19",
    "react-player": "^2.10.1",
    "react-redux": "^9.2.0",
    "redux": "^5.0.0",
    "redux-thunk": "^3.1.0",
    "resize-observer-polyfill": "^1.5.0",
    "rimraf": "^2.7.1",
    "sass": "^1.49.8",
    "sass-lint": "^1.13.1",
    "setimmediate": "^1.0.5",
    "stream-browserify": "^3.0.0",
    "sugarss": "^1.0.1",
    "svgo": "^1.3.0",
    "tar": "^6.1.11",
    "ts-jest": "^29.4.11",
    "tsdown": "^0.22.1",
    "typescript": "^6.0.3",
    "url-search-params-polyfill": "^4.0.0",
    "xml-js": "^1.6.2",
    "xmlhttprequest-ssl": "^2.0.0"
  }
}
